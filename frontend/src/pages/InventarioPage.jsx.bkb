import React, { useState, useEffect, useContext, useMemo } from "react";
import { Link, useSearchParams } from "react-router-dom";
import { motion, AnimatePresence } from "framer-motion";
import {
  ArrowLeft, Server, Plus, Search, Edit, Trash2, Eye, EyeOff,
  X, Save, Monitor, Wifi, HardDrive, Globe, Key, Clock,
  Building2, Copy, Settings, Download, Lock, History,
  ArrowUpDown, ChevronUp, ChevronDown, Check, Laptop, Link2
} from "lucide-react";
import { Button } from "../components/ui/button";
import { Input } from "../components/ui/input";
import { AuthContext } from "../App";
import { toast } from "sonner";

const API = `${process.env.REACT_APP_BACKEND_URL}/api`;

const categoriaIconMap = {
  "Servidores": <HardDrive className="w-5 h-5" />,
  "Dispositivos": <Monitor className="w-5 h-5" />,
  "Cuentas de Acceso": <Key className="w-5 h-5" />,
  "Dominios y Servicios": <Globe className="w-5 h-5" />,
};

const estadoColors = {
  "activo": "bg-emerald-500/20 text-emerald-400 border-emerald-500/30",
  "inactivo": "bg-red-500/20 text-red-400 border-red-500/30",
  "mantenimiento": "bg-amber-500/20 text-amber-400 border-amber-500/30",
};

const ipToNumber = (ip) => {
  if (!ip) return -1;

  const parts = String(ip).trim().split(".");
  if (parts.length !== 4) return -1;

  const nums = parts.map(p => Number(p));
  if (nums.some(n => Number.isNaN(n) || n < 0 || n > 255)) return -1;

  return nums.reduce((acc, oct) => acc * 256 + oct, 0);
};

